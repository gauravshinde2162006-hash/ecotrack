# ═══════════════════════════════════════
# EcoTrack Environment Variables
# Copy this to .env and fill in your keys
# ═══════════════════════════════════════

# ── AI (Required for AI insights) ──────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Maps (Required for real distance) ──
# Free at: https://openrouteservice.org/dev/#/signup
ORS_API_KEY=your_ors_api_key_here

# ── Database ────────────────────────────
DB_PATH=./data/ecotrack.db

# ── Redis ───────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Server ──────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── n8n Integration ─────────────────────
# Webhook URL from your n8n threshold-alert workflow
N8N_THRESHOLD_WEBHOOK=http://localhost:5678/webhook/ecotrack-threshold

# Notification service webhook (Ntfy, Pushover, Slack, etc.)
NOTIFICATION_WEBHOOK_URL=https://ntfy.sh/your-ecotrack-topic

# Weekly report email recipient
REPORT_EMAIL=your@email.com

# n8n encryption key (change in production!)
N8N_ENCRYPTION_KEY=ecotrack-change-this-in-production
