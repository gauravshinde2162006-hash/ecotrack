{
  "name": "ecotrack-backend",
  "version": "1.0.0",
  "description": "EcoTrack API — AI-powered carbon footprint tracker backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node db/seed.js",
    "test": "jest --forceExit --detectOpenHandles",
    "figma-sync": "node ../scripts/syncFigma.js"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/backend/server.js",
      "/backend/db/",
      "/backend/routes/",
      "/backend/middleware/",
      "/backend/services/badgeService.js",
      "/backend/services/claudeService.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  }
}
